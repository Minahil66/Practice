#include<iostream>
using namespace std;
class Tollbooth{
    private:
    int total;
    double money;
    public:
    Tollbooth():total(0), money(0.0){
    }
    void payingCar(){
        total++;
        money+=0.50;
    }
    void dislay(){
        cout<<"Total cars passed: "<<total<<"\nTotal amount: "<<money<<endl;
    }
};
int main(){
    Tollbooth booth;
    cout<<"Car 1 passes:"<<endl;
    booth.payingCar();
    cout<<"Car 2 passes:"<<endl;
    booth.payingCar();
    cout<<"Car 3 passes:"<<endl;
    booth.payingCar();
    booth.dislay();
}